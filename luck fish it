-- ==================== ANTI-CHEAT BYPASS ====================
-- Block report ke server
local Net = require(ReplicatedStorage.Packages.Net)
local oldRemoteEvent = Net.RemoteEvent
Net.RemoteEvent = function(self, name)
    local event = oldRemoteEvent(self, name)
    
    -- Block anti-cheat events
    if name:lower():find("cheat") or name:lower():find("ban") or name:lower():find("report") then
        return {
            FireServer = function() end,
            OnServerEvent = {Connect = function() return {Disconnect = function() end} end}
        }
    end
    
    return event
end

