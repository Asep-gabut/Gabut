-- ==================== ANTI-DETECT METATABLE HOOK ====================
local function secureHook(obj, method, replacement)
    local mt = getrawmetatable(obj)
    if not mt then return false end
    
    setreadonly(mt, false)
    
    -- Simpan original di tempat aman
    local original = mt.__index[method] or obj[method]
    if not original then return false end
    
    -- Ganti dengan proxy
    mt.__index[method] = function(self, ...)
        return replacement(self, original, ...)
    end
    
    setreadonly(mt, true)
    return true
end

