-- ==================== FUNCTIONS ====================
local function isSameTeam(player)
    if not config.teamFilter then return false end
    
    if localPlayer.Team ~= nil and localPlayer.Team == player.Team then
        return true
    end
    
    local myTeamAttr = localPlayer:GetAttribute("Team")
    local theirTeamAttr = player:GetAttribute("Team")
    if myTeamAttr ~= nil and theirTeamAttr ~= nil and myTeamAttr == theirTeamAttr then
        return true
    end
    
    local myChar = localPlayer.Character
    local theirChar = player.Character
    if myChar and theirChar then
        local myCharTeam = myChar:GetAttribute("Team")
        local theirCharTeam = theirChar:GetAttribute("Team")
        if myCharTeam ~= nil and theirCharTeam ~= nil and myCharTeam == theirCharTeam then
            return true
        end
    end
    
    return false
end

local function getCharacterSize(character)
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return Vector3.new(4, 5, 2) end
    
    local min, max = Vector3.new(math.huge, math.huge, math.huge), Vector3.new(-math.huge, -math.huge, -math.huge)
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            local pMin = part.Position - part.Size / 2
            local pMax = part.Position + part.Size / 2
            min = Vector3.new(math.min(min.X, pMin.X), math.min(min.Y, pMin.Y), math.min(min.Z, pMin.Z))
            max = Vector3.new(math.max(max.X, pMax.X), math.max(max.Y, pMax.Y), math.max(max.Z, pMax.Z))
        end
    end
    
    return max - min
end

local function createESP(player)
    if player == localPlayer then return end
    if espObjects[player] then return end
    
    local objects = {}
    
    if config.espBox then
        for i = 1, 4 do
            local line = Drawing.new("Line")
            line.Visible = false
            line.Thickness = 1.5
            line.Transparency = 1
            table.insert(objects, {type = "box", obj = line})
        end
    end
    
    if config.espName then
        local nameText = Drawing.new("Text")
        nameText.Visible = false
        nameText.Size = 14
        nameText.Center = true
        nameText.Outline = true
        nameText.OutlineColor = Color3.new(0, 0, 0)
        nameText.Font = Drawing.Fonts.UI
        table.insert(objects, {type = "name", obj = nameText})
    end
    
    if config.espHealth then
        local healthText = Drawing.new("Text")
        healthText.Visible = false
        healthText.Size = 12
        healthText.Center = true
        healthText.Outline = true
        healthText.OutlineColor = Color3.new(0, 0, 0)
        healthText.Font = Drawing.Fonts.UI
        table.insert(objects, {type = "health", obj = healthText})
        
        local healthBarBg = Drawing.new("Square")
        healthBarBg.Visible = false
        healthBarBg.Filled = true
        healthBarBg.Color = Color3.new(0, 0, 0)
        table.insert(objects, {type = "healthbar_bg", obj = healthBarBg})
        
        local healthBar = Drawing.new("Square")
        healthBar.Visible = false
        healthBar.Filled = true
        table.insert(objects, {type = "healthbar", obj = healthBar})
    end
    
    if config.espDistance then
        local distText = Drawing.new("Text")
        distText.Visible = false
        distText.Size = 12
