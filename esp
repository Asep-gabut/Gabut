local function updateESP()
    if not config.espEnabled then
        for _, objects in pairs(espObjects) do
            for _, item in ipairs(objects) do
                item.obj.Visible = false
            end
        end
        return
    end
    
    for player, objects in pairs(espObjects) do
        -- FIX: Cek player valid
        if not player or not player.Parent then
            for _, item in ipairs(objects) do item.obj.Visible = false end
            continue
        end
        
        local character = player.Character
        local humanoid = character and character:FindFirstChild("Humanoid")
        local hrp = character and character:FindFirstChild("HumanoidRootPart")
        
        if not character or not humanoid or not hrp or humanoid.Health <= 0 then
            for _, item in ipairs(objects) do item.obj.Visible = false end
            continue
        end
        
        local pos = hrp.Position
        local screenPos, onScreen = camera:WorldToViewportPoint(pos)
        local distance = (pos - camera.CFrame.Position).Magnitude
        
        if not onScreen or distance > config.espMaxDistance then
            for _, item in ipairs(objects) do item.obj.Visible = false end
            continue
        end
        
        local isTeammate = isSameTeam(player)
        local color = (isTeammate and config.espTeamColor) and config.espTeamColor or config.espColor
        
        local size = getCharacterSize(character)
        local top = camera:WorldToViewportPoint(pos + Vector3.new(0, size.Y / 2, 0))
        local bottom = camera:WorldToViewportPoint(pos - Vector3.new(0, size.Y / 2, 0))
        local height = math.abs(top.Y - bottom.Y)
        local width = height * 0.6
        
        local boxTopLeft = Vector2.new(screenPos.X - width / 2, top.Y)
        local boxTopRight = Vector2.new(screenPos.X + width / 2, top.Y)
        local boxBottomLeft = Vector2.new(screenPos.X - width / 2, bottom.Y)
        local boxBottomRight = Vector2.new(screenPos.X + width / 2, bottom.Y)
        
        for _, item in ipairs(objects) do
            if item.type == "box" and config.espBox then
                local lines = {}
                for _, obj in ipairs(objects) do
                    if obj.type == "box" then table.insert(lines, obj.obj) end
                end
                
                lines[1].From = boxTopLeft; lines[1].To = boxTopRight
                lines[2].From = boxTopRight; lines[2].To = boxBottomRight
                lines[3].From = boxBottomRight; lines[3].To = boxBottomLeft
                lines[4].From = boxBottomLeft; lines[4].To = boxTopLeft
                
                for _, line in ipairs(lines) do
                    line.Color = color
                    line.Visible = true
                end
                
            elseif item.type == "name" and config.espName then
                item.obj.Text = player.Name
                item.obj.Position = Vector2.new(screenPos.X, boxTopLeft.Y - 20)
                item.obj.Color = color
                item.obj.Visible = true
                
            elseif item.type == "health" and config.espHealth then
                local healthPercent = humanoid.Health / humanoid.MaxHealth
                item.obj.Text = math.floor(humanoid.Health) .. "/" .. math.floor(humanoid.MaxHealth)
                item.obj.Position = Vector2.new(screenPos.X, boxBottomLeft.Y + 5)
                item.obj.Color = Color3.fromRGB(255 - (healthPercent * 255), healthPercent * 255, 0)
                item.obj.Visible = true
                
            elseif item.type == "healthbar_bg" and config.espHealth then
                item.obj.Size = Vector2.new(width + 4, 6)
                item.obj.Position = Vector2.new(boxTopLeft.X - 2, boxTopLeft.Y - 10)
                item.obj.Visible = true
                
            elseif item.type == "healthbar" and config.espHealth then
                local healthPercent = humanoid.Health / humanoid.MaxHealth
                item.obj.Size = Vector2.new((width + 4) * healthPercent, 6)
                item.obj.Position = Vector2.new(boxTopLeft.X - 2, boxTopLeft.Y - 10)
                item.obj.Color = Color3.fromRGB(255 - (healthPercent * 255), healthPercent * 255, 0)
                item.obj.Visible = true
                
            elseif item.type == "distance" and config.espDistance then
                item.obj.Text = math.floor(distance) .. "m"
                item.obj.Position = Vector2.new(screenPos.X, boxBottomLeft.Y + 20)
                item.obj.Color = color
                item.obj.Visible = true
                
            elseif item.type == "tracer" and config.espTracers then
                item.obj.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                item.obj.To = Vector2.new(screenPos.X, screenPos.Y)
                item.obj.Color = color
                item.obj.Visible = true
            end
        end
    end
end

-- ==================== AIMBOT ====================
local PRIORITY_PARTS = {"Head", "UpperTorso", "Torso", "HumanoidRootPart"}

local raycastParams = RaycastParams.new()
raycastParams.FilterType = Enum.RaycastFilterType.Exclude

local function updateRaycastFilter()
    local filterList = {}
    if localPlayer.Character then
        table.insert(filterList, localPlayer.Character)
    end
    raycastParams.FilterDescendantsInstances = filterList
end

local function shapecastVisibility(part, character)
    if not part then return false, nil end
    local direction = part.Position - camera.CFrame.Position
    updateRaycastFilter()
    
    local result = workspace:Shapecast(part, direction, raycastParams)
    if not result then return true, part.Position end
    if result.Instance:IsDescendantOf(character) then return true, result.Position end
    return false, nil
end

local function isPointVisible(point, character)
    local origin = camera.CFrame.Position
    local direction = point - origin
    updateRaycastFilter()
    
    local result = workspace:Raycast(origin, direction, raycastParams)
    if not result then return true, point end
    if result.Instance:IsDescendantOf(character) then return true, point end
    return false, nil
end

local function raycastMultiVisibility(part, character)
    if not part then return false, nil end
    local origin = camera.CFrame.Position
    local partCF = part.CFrame
    local partSize = part.Size
    
    local checkPoints = {
        part.Position,
        partCF:PointToWorldSpace(Vector3.new(0, -partSize.Y/3, 0)),
        partCF:PointToWorldSpace(Vector3.new(0, partSize.Y/3, 0)),
        partCF:PointToWorldSpace(Vector3.new(partSize.X/3, 0, 0)),
        partCF:PointToWorldSpace(Vector3.new(-partSize.X/3, 0, 0)),
        partCF:PointToWorldSpace(Vector3.new(0, 0, partSize.Z/3)),
        partCF:PointToWorldSpace(Vector3.new(0, 0, -partSize.Z/3)),
    }
    
    for _, checkPos in ipairs(checkPoints) do
        local visible, aimPoint = isPointVisible(checkPos, character)
        if visible then return true, aimPoint end
    end
    return false, nil
end

local function getVisiblePartWithPoint(character)
    if not config.wallCheck then
        for _, partName in ipairs(PRIORITY_PARTS) do
            local part = character:FindFirstChild(partName)
            if part then return part, part.Position end
        end
        return nil, nil
    end
    
    local method = config.visibilityMethod
    if method == "Auto" then
        method = shapecastAvailable and "Shapecast" or "RaycastMulti"
    end
    
    for _, partName in ipairs(PRIORITY_PARTS) do
        local part = character:FindFirstChild(partName)
        if not part then continue end
        
        local isVisible, aimPoint
        if method == "Shapecast" and shapecastAvailable then
            isVisible, aimPoint = shapecastVisibility(part, character)
        else
            isVisible, aimPoint = raycastMultiVisibility(part, character)
        end
        
        if isVisible and aimPoint then return part, aimPoint end
    end
    return nil, nil
end

local function getNearestTarget()
    local best = nil
    local bestDist = math.huge
    local bestAimPoint = nil
    local center = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)

    for _, player in ipairs(Players:GetPlayers()) do
        if player == localPlayer then continue end
        if isSameTeam(player) then continue end

        local char = player.Character
        if not char then continue end
        local humanoid = char:FindFirstChild("Humanoid")
        if not humanoid or humanoid.Health <= 0 then continue end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        local screenPos, onScreen = camera:WorldToViewportPoint(root.Position)
        if not onScreen then continue end

        local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
        if screenDist > config.fovSize then continue end

        local visiblePart, aimPoint = getVisiblePartWithPoint(char)
        if config.wallCheck and (not visiblePart or not aimPoint) then continue end

        if screenDist < bestDist then
            bestDist = screenDist
            best = player
            bestAimPoint = aimPoint
        end
    end

    if not best then return nil, nil end
    return best, bestAimPoint
end

