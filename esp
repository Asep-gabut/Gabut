                v_u_30[v_u_27].lastfired = 0
            end
        end
        
        if config.instantReload then
            local env = getfenv()
            local v_u_30 = env.v_u_30
            local v_u_27 = env.v_u_27
            if v_u_30 and v_u_27 and v_u_30[v_u_27] then
                local weapon = env.GI and env.GI(v_u_27)
                if weapon then
                    local maxAmmo = weapon:GetAttribute("Ammo") or 30
                    v_u_30[v_u_27].Ammo = maxAmmo
                    v_u_30[v_u_27].StoredAmmo = 999
                    v_u_30[v_u_27].Reloading = nil
                end
            end
            
            -- Force reload flag false
            local v_u_29 = env.v_u_29
            if v_u_29 ~= nil then
                env.v_u_29 = false
            end
        end
    end
end)

