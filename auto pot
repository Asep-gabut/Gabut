local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local plr = Players.LocalPlayer
local ITEM_NAMES = {
    "All Season Potion",
    "Glitched Potion", 
    "Luck Potion",
    "Lure Speed Potion",
}


local claimEvent = ReplicatedStorage.packages.Net["RE/PersonalAquarium/ClaimRewards"]

task.spawn(function()
    while true do
        pcall(function()
            claimEvent:FireServer()
        end)
        task.wait(60)
    end
end)

local function getTool(name)
    local backpack = plr:FindFirstChild("Backpack")
    if backpack then
        for _, t in ipairs(backpack:GetChildren()) do
            if t.Name == name and t:IsA("Tool") then
                return t
            end
        end
    end
    return nil
end

task.spawn(function()
    while true do
        for _, itemName in ipairs(ITEM_NAMES) do
            local tool = getTool(itemName)
            if tool then
                local hum = plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
                if hum then
                    hum:EquipTool(tool)
                    task.wait(0.2)
                    
                    pcall(function()
                        tool:Activate()
                    end)
                    task.wait(0.2)
                    
                    hum:UnequipTools()
                    task.wait(0.2)
                end
            end
            task.wait()
        end
        task.wait(60)
    end
end)

task.spawn(function()
    while true do
        local Rod = getTool("Shady Rod")
            local xim = plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
            if xim then
                pcall(function()
                    xim:EquipTool(Rod)
                end)
            end
        task.wait(20)
    end
end)

task.spawn(function()
    while true do
        local Bait = getTool("Coral Geode")
            local bgs = plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
            if bgs then
                pcall(function()
                    xim:EquipTool(Bait)
                end)
            end
        task.wait(1)
    end
end)