-- ==================== GOLD PAN AUTO ====================
local PointToRegion = require(game.ReplicatedStorage.Modules.Location.PointToRegion)
local player = game.Players.LocalPlayer
local hrp = player.Character.HumanoidRootPart

local isRunning = false
local depositPos = nil
local waterPos = nil
local searchRadius = 50
local searchStep = 10
local scanInterval = 5

-- Cleanup connections tracker
local connections = {}
local function addConnection(conn)
    table.insert(connections, conn)
    return conn
end
local function cleanupConnections()
    for _, conn in connections do
        if conn and conn.Connected then
            conn:Disconnect()
        end
    end
    connections = {}
end

local function getPan()
    local char = player.Character
    if not char then return nil end
    for _, tool in char:GetChildren() do
        if tool:IsA("Tool") and tool:FindFirstChild("Scripts") then
            local s = tool.Scripts
            if s:FindFirstChild("Collect") and s:FindFirstChild("Pan") and s:FindFirstChild("Shake") then
                return tool, "character"
            end
        end
    end
    local bp = player:FindFirstChild("BackpackTwo")
    if not bp then return nil end
    for _, tool in bp:GetChildren() do
        if tool:IsA("Tool") and tool:FindFirstChild("Scripts") then
            local s = tool.Scripts
            if s:FindFirstChild("Collect") and s:FindFirstChild("Pan") and s:FindFirstChild("Shake") then
                return tool, "backpack"
            end
        end
    end
    return nil
end

local function findNearestRegion(targetRegion)
    local bestPos = nil
    local bestDist = math.huge
    local origin = hrp.Position
    for x = -searchRadius, searchRadius, searchStep do
        for z = -searchRadius, searchRadius, searchStep do
            local testPos = Vector3.new(origin.X + x, origin.Y, origin.Z + z)
            local ok, region = pcall(PointToRegion.GetPanningRegion, testPos)
            if ok and region == targetRegion then
                local dist = (testPos - origin).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    bestPos = testPos
                end
            end
        end
    end
    return bestPos
end

local function teleport(pos)
    hrp.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
    task.wait(0.5)
end

