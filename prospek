local function updateStatus(text)
    if statusLabel and statusLabel._titleLabel then
        statusLabel._titleLabel.Text = "Status: " .. text
    end
end

local function updatePanLabel()
    local pan, loc = getPan()
    if pan then
        panLabel._titleLabel.Text = "Pan: " .. pan.Name .. " (" .. loc .. ")"
    else
        panLabel._titleLabel.Text = "Pan: Mana pan lu tol"
    end
end

-- Auto scan loop independent
local scanRunning = true
task.spawn(function()
    while scanRunning do
        updatePanLabel()
        scanLabel._titleLabel.Text = "Scan: Scanning..."
        local newDeposit = findNearestRegion("Deposit")
        local newWater = findNearestRegion("Water")
        if newDeposit then depositPos = newDeposit end
        if newWater then waterPos = newWater end
        if depositPos and waterPos then
            scanLabel._titleLabel.Text = "Scan: Ketemu"
        else
            scanLabel._titleLabel.Text = "Scan: Belum ketemu tol"
        end
        task.wait(scanInterval)
    end
end)

-- Auto Farm Toggle
MainTab:AddSection("Farm", true):AddToggle({
    Title = "Auto Farm",
    Default = false,
    NoSave = false,
    Callback = function(val)
        isRunning = val
        if val then
            local pan = getPan()
            if not pan then
                updateStatus("Equip pan nya tol")
                Library:MakeNotify({
                    Title = "Error",
                    Description = "Equip tol.",
                    Color = Color3.fromRGB(220, 50, 50),
                    Delay = 3
                })
                isRunning = false
                return
            end
            if not depositPos or not waterPos then
                updateStatus("Sabar tol")
                repeat task.wait(0.1) until (depositPos and waterPos) or not isRunning
            end
            task.spawn(function()
                while isRunning do
                    local currentPan, location = getPan()
                    if not currentPan then
                        updateStatus("Pan hilang!")
                        Library:MakeNotify({
                            Title = "Error",
                            Description = "Pan lu mana tol",
                            Color = Color3.fromRGB(220, 50, 50),
                            Delay = 3
                        })
                        isRunning = false
                        break
                    end

                    local pan_tool = location == "character" and currentPan
                        or player.BackpackTwo:FindFirstChild(currentPan.Name)

                    if not pan_tool then
                        isRunning = false
                        break
                    end

                    -- Collect loop sampai pan full
                    if depositPos and isRunning then
                        updateStatus("Asep ganteng")
                        teleport(depositPos)
                        repeat
                            pcall(function()
                                pan_tool.Scripts.Collect:InvokeServer(1, false)
                            end)
                            local fill = pan_tool:GetAttribute("Fill") or 0
                            local capacity = player:WaitForChild("Stats"):GetAttribute("Capacity") or 1
                            task.wait(0.1)
                        until fill >= capacity or not isRunning
                    end

                    -- Pan + shake loop di water
                    if waterPos and isRunning then
                        currentPan, location = getPan()
                        if not currentPan then break end
                        pan_tool = location == "character" and currentPan
                            or player.BackpackTwo:FindFirstChild(currentPan.Name)
                        if not pan_tool then break end

                        updateStatus("Asep ganteng")
                        teleport(waterPos)
                        pcall(function()
                            pan_tool.Scripts.Pan:InvokeServer()
                        end)
                        task.wait(0.5)
                        updateStatus("Shaking...")
                        while isRunning and player.Character:GetAttribute("Panning") do
                            pcall(function()
                                pan_tool.Scripts.Shake:FireServer()
                            end)
                            task.wait(0.1)
                        end
                        task.wait(0.5)
                    end
                end
                updateStatus("Stopped")
            end)
        else
            updateStatus("Idle")
        end
    end
})

